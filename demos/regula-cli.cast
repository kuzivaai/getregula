{"version": 2, "width": 92, "height": 30, "timestamp": 1775767000, "title": "Regula 1.6.0 — value-first quickstart on a real hiring AI script", "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}}
[0.0, "o", "$ "]
[0.5, "o", "pip install regula-ai"]
[1.5, "o", "\r\n"]
[1.6, "o", "Successfully installed regula-ai-1.6.0\r\n"]
[2.0, "o", "$ "]
[2.4, "o", "cat demo.py"]
[3.0, "o", "\r\n"]
[3.1, "o", "import openai\r\n"]
[3.15, "o", "def classify_resume(resume_text):\r\n"]
[3.2, "o", "    client = openai.OpenAI()\r\n"]
[3.25, "o", "    reply = client.chat.completions.create(\r\n"]
[3.3, "o", "        model='gpt-4',\r\n"]
[3.35, "o", "        messages=[{'role':'user','content':f'Score this resume: {resume_text}'}])\r\n"]
[3.4, "o", "    return reply.choices[0].message.content\r\n"]
[3.6, "o", "$ "]
[4.2, "o", "regula quickstart"]
[5.0, "o", "\r\n"]
[5.2, "o", "\r\nRegula Quickstart\r\n\r\n"]
[5.4, "o", "  Created: ./regula-policy.yaml\r\n\r\n"]
[5.6, "o", "  First scan complete (0.0s)\r\n"]
[5.65, "o", "  Files scanned:      1\r\n"]
[5.7, "o", "  BLOCK findings:     1\r\n"]
[5.75, "o", "  WARN findings:      0\r\n"]
[5.8, "o", "  INFO findings:      0\r\n\r\n"]
[6.0, "o", "  Top findings:\r\n"]
[6.1, "o", "    \u001b[31m[BLOCK]\u001b[0m [ 88] demo.py\r\n"]
[6.15, "o", "          Annex III, Category 4\r\n"]
[6.2, "o", "          Employment and workers management\r\n\r\n"]
[6.5, "o", "  Next steps:\r\n"]
[6.55, "o", "    1. Edit regula-policy.yaml \u2014 set your organisation name and AI officer\r\n"]
[6.6, "o", "    2. Run 'regula check .' to scan your project\r\n"]
[6.65, "o", "    3. Run 'regula doctor' to verify your setup\r\n"]
[6.7, "o", "    4. Review 1 BLOCK finding(s) \u2014 these would fail CI\r\n"]
[6.75, "o", "    5. Run 'regula install claude-code' to add pre-commit hooks\r\n"]
[6.8, "o", "    6. Run 'regula gap --project .' for compliance gap analysis\r\n\r\n"]
[7.5, "o", "$ "]
[8.0, "o", "regula classify --file demo.py"]
[8.6, "o", "\r\n"]
[8.8, "o", "\u001b[31mHIGH-RISK\u001b[0m: Employment and workers management - Articles 9, 10, 11, 12, 13, 14, 15\r\n"]
