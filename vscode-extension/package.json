{
  "name": "regula-vscode",
  "displayName": "Regula — EU AI Act Compliance",
  "description": "Inline EU AI Act risk indicators for AI code. Blocks prohibited practices, warns on high-risk patterns.",
  "version": "0.1.0",
  "publisher": "kuzivaai",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Linters", "Other"],
  "keywords": ["eu-ai-act", "compliance", "governance", "ai-safety"],
  "activationEvents": ["onLanguage:python", "onLanguage:javascript", "onLanguage:typescript"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "regula.checkFile",
        "title": "Regula: Check Current File"
      },
      {
        "command": "regula.checkProject",
        "title": "Regula: Check Entire Project"
      }
    ],
    "configuration": {
      "title": "Regula",
      "properties": {
        "regula.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python interpreter with Regula installed"
        },
        "regula.minTier": {
          "type": "string",
          "enum": ["minimal_risk", "limited_risk", "high_risk", "prohibited"],
          "default": "limited_risk",
          "description": "Minimum risk tier to report"
        },
        "regula.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run Regula when saving a file"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
